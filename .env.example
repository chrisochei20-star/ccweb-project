# Copy to .env for local development (do not commit .env)

# Local Vite dev: forward /api to your Node server (no hardcoded host in vite.config — set this in .env).
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:3000

# Server: prefer these in production so URL parsing and logs match your public host (no localhost).
# CCWEB_API_PUBLIC_URL=https://ccweb-render-main.onrender.com
# PUBLIC_APP_URL=https://ccweb-project-hoiy.vercel.app
# CCWEB_REQUEST_PARSE_BASE=https://ccweb-render-main.onrender.com

# Template values for Vercel + Render (copy into Vercel env UI; replace Supabase placeholders if used):
VITE_API_BASE_URL=https://ccweb-render-main.onrender.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
