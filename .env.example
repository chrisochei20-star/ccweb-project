# Copy to .env and adjust (never commit .env)
# PORT=3000
# MONGODB_URI=
# ETHERSCAN_API_KEY=

# Auth — required in production (min 32 chars)
# AUTH_JWT_SECRET=openssl-rand-hex-32-or-longer
# AUTH_ACCESS_EXPIRES=15m
# AUTH_REFRESH_EXPIRES=14d
# AUTH_REFRESH_IN_BODY=1
# AUTH_COOKIE_SECURE=1
# PUBLIC_APP_URL=https://your-domain.com
# CCWEB_ALLOWED_ORIGINS=https://your-domain.com,http://localhost:5173
# TRUST_PROXY=1
# AUTH_DEBUG=1

# Vite (frontend) — WalletConnect for profile wallet sign-in
# VITE_WALLETCONNECT_PROJECT_ID=your-reown-project-id

# Optional: admin API for telemetry summary and user list (header X-CCWEB-Admin)
# CCWEB_ADMIN_KEY=long-random-secret

# PostgreSQL (persistent auth, growth hub, community). Migrations run on server start unless CCWEB_SKIP_MIGRATIONS=1
# DATABASE_URL=postgres://user:pass@host:5432/ccweb
# CCWEB_SKIP_MIGRATIONS=1

# Redis (optional; API caching falls back to in-process LRU when unset)
# REDIS_URL=redis://127.0.0.1:6379

# AI execution (agent/workflow runs — developer API + platform /api/v1/agents/run)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Live token scans (required for production gate when NODE_ENV=production)
# ETHERSCAN_API_KEY=
# ETHERSCAN_API_URL=https://api.etherscan.io/api

# Production: server exits on startup if DATABASE_URL, AUTH_JWT_SECRET (32+ chars), Stripe keys, OPENAI_API_KEY, ETHERSCAN_API_KEY are missing
# NODE_ENV=production

# Viral growth / referrals (bonus learning credits + XP when referee activates via session or AI tool use)
# CCWEB_REFERRAL_BONUS_CENTS=250
# CCWEB_REFERRAL_XP=150
# CCWEB_REFERRER_XP=200
# CCWEB_STREAK_7_BONUS_CENTS=100

# Growth Hub: seed demo marketplace listings on empty DB (default on in dev). Set 0 in production unless onboarding samples wanted.
# CCWEB_SEED_GROWTH_SAMPLES=0

# Frontend Google Identity Services (same audience as GOOGLE_CLIENT_ID on API when using Google login button)
# VITE_GOOGLE_CLIENT_ID=

# OAuth ID token verification (optional; email/password still works)
# GOOGLE_CLIENT_ID=
# APPLE_CLIENT_ID=

# Stripe (escrow checkout + webhook). Requires DATABASE_URL for checkout handler.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Ops
# LOG_LEVEL=info
# API_RATE_LIMIT_MAX=400

# Optional: social narrative keywords (Early Signals dashboard)
# TWITTER_BEARER_TOKEN=   # X API v2 search recent (optional)
# CCWEB_TWITTER_SEARCH_QUERY=(crypto OR solana) -is:retweet lang:en
# CCWEB_REDDIT_SUBS=cryptocurrency,ethereum,solana

# Developer API revenue: pass ccwebProjectId in growth checkout body to attribute Stripe rows in platform_transactions
# CCWEB_PLATFORM_REVENUE_SHARE_PCT=8
# FACEBOOK_PAGE_ACCESS_TOKEN=
# FACEBOOK_PAGE_ID=me
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_AUTHOR_URN=urn:li:person:xxxx
