# Copy to .env and adjust (never commit .env)
# PORT=3000
# MONGODB_URI=
# ETHERSCAN_API_KEY=

# Auth — required in production (min 32 chars)
# AUTH_JWT_SECRET=openssl-rand-hex-32-or-longer
# AUTH_ACCESS_EXPIRES=15m
# AUTH_REFRESH_EXPIRES=14d
# AUTH_REFRESH_IN_BODY=1
# AUTH_COOKIE_SECURE=1
# PUBLIC_APP_URL=https://your-domain.com
# CCWEB_API_PUBLIC_URL=https://api.your-domain.com
# VITE_API_BASE_URL=https://api.your-domain.com
# If unset at build time, optional runtime fallback: index.html <meta name="ccweb-api-base-url" content="https://api.your-domain.com">
# CCWEB_ALLOWED_ORIGINS=https://your-domain.com,http://localhost:5173
# TRUST_PROXY=1
# AUTH_DEBUG=1

# Vite (frontend) — WalletConnect for profile wallet sign-in
# VITE_WALLETCONNECT_PROJECT_ID=your-reown-project-id
# VITE_APP_ENV=development
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:3000
# Native / long-lived sessions: persist JWT in localStorage instead of sessionStorage (Capacitor, PWA)
# VITE_SESSION_LOCAL_STORAGE=false

# Optional: admin API for telemetry summary and user list (header X-CCWEB-Admin)
# CCWEB_ADMIN_KEY=long-random-secret

# PostgreSQL (persistent auth, growth hub, community). Migrations: `npm run db:migrate` (also run on build + before listen unless CCWEB_SKIP_MIGRATIONS=1)
# DATABASE_URL=postgres://user:pass@host:5432/ccweb
# CCWEB_SKIP_MIGRATIONS=1
# CCWEB_MIGRATE_RETRIES=5
# CCWEB_SEED_DEMO=0
# CCWEB_ALLOW_START_WITHOUT_DB=0

# Redis (optional; API caching falls back to in-process LRU when unset)
# REDIS_URL=redis://127.0.0.1:6379

# AI execution (agent/workflow runs — developer API + platform /api/v1/agents/run)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Live token scans (set ETHERSCAN_API_KEY for full EVM verification; DexScreener still works without it)
# ETHERSCAN_API_KEY=
# ETHERSCAN_API_URL=https://api.etherscan.io/api

# Production gate requires DATABASE_URL, PUBLIC_APP_URL, CCWEB_ALLOWED_ORIGINS, AUTH_JWT_SECRET when NODE_ENV=production.
# OpenAI / Etherscan / Stripe optional — mock or degraded behavior until keys are set.
# NODE_ENV=production

# Viral growth / referrals (bonus learning credits + XP when referee activates via session or AI tool use)
# CCWEB_REFERRAL_BONUS_CENTS=250
# CCWEB_REFERRAL_XP=150
# CCWEB_REFERRER_XP=200
# CCWEB_STREAK_7_BONUS_CENTS=100

# Monetization engine (monthly limits by tier, credit debit when over quota, demand multiplier from live sessions)
# Subscription tiers from Stripe learning checkout map to pro/premium; otherwise user is free tier.
# CCWEB_LIMIT_FREE_SCANS=25
# CCWEB_LIMIT_PRO_SCANS=500
# CCWEB_LIMIT_PREMIUM_SCANS=50000
# CCWEB_LIMIT_FREE_INTEL=60
# CCWEB_LIMIT_PRO_INTEL=2000
# CCWEB_LIMIT_PREMIUM_INTEL=50000
# CCWEB_LIMIT_FREE_AI_RUNS=20
# CCWEB_LIMIT_PRO_AI_RUNS=400
# CCWEB_LIMIT_PREMIUM_AI_RUNS=50000
# CCWEB_LIMIT_FREE_HUB_AGENTS=40
# CCWEB_LIMIT_FREE_HUB_WORKFLOWS=15
# CCWEB_PRICE_SCAN_USD=0.39
# CCWEB_PRICE_INTEL_USD=0.15
# CCWEB_PRICE_AI_RUN_USD=0.08
# CCWEB_CREDIT_MARKUP=1
# CCWEB_DEMAND_MULT_CAP=1.35
# CCWEB_DEMAND_MULT_PER_LIVE_SESSION=0.02
# CCWEB_HUB_AGENT_USD=0.12
# CCWEB_HUB_WORKFLOW_USD=0.18

# Growth Hub: seed demo marketplace listings on empty DB (default on in dev). Set 0 in production unless onboarding samples wanted.
# CCWEB_SEED_GROWTH_SAMPLES=0

# Frontend Google Identity Services (same audience as GOOGLE_CLIENT_ID on API when using Google login button)
# VITE_GOOGLE_CLIENT_ID=

# OAuth ID token verification (optional; email/password still works)
# GOOGLE_CLIENT_ID=
# APPLE_CLIENT_ID=

# Stripe (escrow checkout + webhook). Requires DATABASE_URL for checkout handler.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Flutterwave (subscriptions, course checkout, tips, AI packs). Set secret hash from Flutterwave dashboard → Webhooks.
# FLUTTERWAVE_PUBLIC_KEY=
# FLUTTERWAVE_SECRET_KEY=
# FLUTTERWAVE_SECRET_HASH=
# Optional pricing defaults (subscription uses USD or NGN env; AI packs use *_CENTS):
# FLUTTERWAVE_SUBSCRIPTION_USD=15
# FLUTTERWAVE_SUBSCRIPTION_NGN=15000
# FLUTTERWAVE_SUB_BONUS_CREDITS_CENTS=500
# CCWEB_CREATOR_PLATFORM_FEE_BPS=1200
# Payout queue: encrypt bank payloads at rest (64 hex chars). Thresholds & velocity limits reduce fraud risk.
# CCWEB_PAYOUT_ENCRYPTION_KEY=
# CCWEB_PAYOUT_MIN_USD_CENTS=2000
# CCWEB_PAYOUT_MIN_NGN_MINOR=500000
# CCWEB_PAYOUT_MAX_USD_MINOR=10000000
# CCWEB_PAYOUT_MAX_NGN_MINOR=1000000000
# CCWEB_PAYOUT_MAX_ACTIVE_PER_24H=3
# FLUTTERWAVE_PAYOUT_ENABLED=0
# When 1, new marketplace listings require admin moderation before they appear publicly.
# CCWEB_MP_REQUIRE_LISTING_REVIEW=0
# CCWEB_AUDIT_IP_SALT=

# LOG_LEVEL=info
# API_RATE_LIMIT_MAX=400

# Media uploads (profile, chat, course thumbnails). Prefer Cloudinary in production.
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# Or discrete vars:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CCWEB_UPLOAD_MAX_BYTES=12582912

# Optional: social narrative keywords (Early Signals dashboard)
# TWITTER_BEARER_TOKEN=   # X API v2 search recent (optional)
# CCWEB_TWITTER_SEARCH_QUERY=(crypto OR solana) -is:retweet lang:en
# CCWEB_REDDIT_SUBS=cryptocurrency,ethereum,solana

# Developer API revenue: pass ccwebProjectId in growth checkout body to attribute Stripe rows in platform_transactions
# CCWEB_PLATFORM_REVENUE_SHARE_PCT=8
# FACEBOOK_PAGE_ACCESS_TOKEN=
# FACEBOOK_PAGE_ID=me
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_AUTHOR_URN=urn:li:person:xxxx
