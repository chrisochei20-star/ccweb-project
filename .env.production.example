# CCWEB — production environment template (copy to `.env` on the server; never commit real `.env`)

# --- Runtime (Node API) ---
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
TRUST_PROXY=1
# PG_CONNECTION_TIMEOUT_MS=15000

# PostgreSQL (required in production)
DATABASE_URL=postgres://user:password@host:5432/ccweb

# Public URLs (HTTPS in production) — use your live Vercel SPA origin
PUBLIC_APP_URL=https://ccweb-project-hoiy.vercel.app
CCWEB_API_PUBLIC_URL=https://ccweb-api-production.up.railway.app
# Must include every browser origin that calls the API (Vercel preview URLs change per deployment; add each or use * for open beta)
CCWEB_ALLOWED_ORIGINS=https://ccweb-project-hoiy.vercel.app
# CCWEB_ALLOWED_ORIGINS=https://ccweb-project-hoiy.vercel.app,https://ccweb-project-*.vercel.app
# CCWEB_ALLOWED_ORIGINS=*

# Auth (AUTH_JWT_SECRET min 32 characters)
AUTH_JWT_SECRET=replace-with-openssl-rand-hex-32-or-longer
AUTH_ACCESS_EXPIRES=15m
AUTH_REFRESH_EXPIRES=14d
AUTH_COOKIE_SECURE=1
AUTH_REFRESH_IN_BODY=1

# Stripe (optional for beta — omit both until payments go live; API returns 503 on payment routes until set)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# AI + chain APIs (optional for beta — omit for mock AI + degraded wallet scans)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# CCWEB_REQUIRE_OPENAI=1
# ETHERSCAN_API_KEY=...

# Live token scans — stronger EVM checks when ETHERSCAN_API_KEY set
# ETHERSCAN_API_URL=https://api.etherscan.io/api

# Production gate requires: DATABASE_URL, PUBLIC_APP_URL (https), CCWEB_ALLOWED_ORIGINS, AUTH_JWT_SECRET (32+ chars).
# CCWEB_BOOT_WARN_ONLY=1 — warn instead of exit for PUBLIC_APP_URL / CCWEB_ALLOWED_ORIGINS (pairs with open CORS when origins unset).
# CCWEB_SKIP_PRODUCTION_GATE=1 — emergency only; skips all gate checks.
# Stripe, OpenAI, Etherscan optional — see logs when omitted.
# REDIS_URL=redis://...
# CCWEB_ADMIN_KEY=...
# GOOGLE_CLIENT_ID=...

# --- Frontend build (Vite / Vercel / Netlify) ---
# Primary: set at build time so import.meta.env.VITE_API_BASE_URL is baked into dist/.
# This repo includes committed `.env.production` defaulting to the Railway API URL below (override per fork).
# VITE_API_BASE_URL=https://ccweb-api-production.up.railway.app
# VITE_CCWEB_API_DEBUG=1  # optional one-off: log resolved API/auth/Socket base in the browser console
# VITE_APP_ENV=production
# VITE_GOOGLE_CLIENT_ID=...
# VITE_WALLETCONNECT_PROJECT_ID=...

# --- API host (Railway or any Node host) ---
# Same DATABASE_URL / PUBLIC_APP_URL / CCWEB_ALLOWED_ORIGINS / AUTH_* as above.
# CCWEB_ALLOWED_ORIGINS must include your Vercel origin or use * for open-beta CORS.

# --- Local Vite dev only (optional; defaults to http://127.0.0.1:3000) ---
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:3000
