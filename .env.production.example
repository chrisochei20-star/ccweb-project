# CCWEB — production environment template (copy to `.env` on the server; never commit real `.env`)

# --- Runtime (Node API) ---
NODE_ENV=production
PORT=3000
TRUST_PROXY=1

# PostgreSQL (required in production)
DATABASE_URL=postgres://user:password@host:5432/ccweb

# Public URLs (HTTPS in production)
PUBLIC_APP_URL=https://app.example.com
CCWEB_API_PUBLIC_URL=https://api.example.com
# Comma-separated origins, or use * for open beta (allows any browser Origin with credentials via dynamic CORS)
CCWEB_ALLOWED_ORIGINS=https://app.example.com
# CCWEB_ALLOWED_ORIGINS=*

# Auth (AUTH_JWT_SECRET min 32 characters)
AUTH_JWT_SECRET=replace-with-openssl-rand-hex-32-or-longer
AUTH_ACCESS_EXPIRES=15m
AUTH_REFRESH_EXPIRES=14d
AUTH_COOKIE_SECURE=1
AUTH_REFRESH_IN_BODY=1

# Stripe (optional for beta — omit both until payments go live; API returns 503 on payment routes until set)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# AI + on-chain (production gate)
OPENAI_API_KEY=sk-...
ETHERSCAN_API_KEY=...

# Optional
# REDIS_URL=redis://...
# CCWEB_ADMIN_KEY=...
# GOOGLE_CLIENT_ID=...

# --- Frontend build (Vite; set when building `dist/` for CDN deploy) ---
# VITE_API_BASE_URL=https://api.example.com
# VITE_APP_ENV=production
# VITE_WALLETCONNECT_PROJECT_ID=...

# --- Local Vite dev only (optional; defaults to http://127.0.0.1:3000) ---
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:3000
