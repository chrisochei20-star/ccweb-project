{
  "name": "ccweb-project",
  "version": "1.1.0",
  "private": true,
  "description": "The world's first AI-powered Web3 Academy and Business Engine",
  "main": "server.js",
  "scripts": {
    "serve": "node server.js",
    "dev": "vite",
    "dev:api": "node server.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "record:preview": "PW_SLOW_MO=450 CI=1 playwright test e2e/preview-recording.spec.js --project=chromium",
    "mobile:sync": "npm run build && npx cap sync"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "web3",
    "ai",
    "academy",
    "business-engine"
  ],
