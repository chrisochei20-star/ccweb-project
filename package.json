    "bcrypt": "^6.0.0",
    "bs58": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "ethers": "^6.13.5",
    "express": "^5.1.0",
    "framer-motion": "^12.38.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "lucide-react": "^1.8.0",
    "mongodb": "^6.16.0",
