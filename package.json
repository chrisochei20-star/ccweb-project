    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.9.4",
    "recharts": "^3.8.1",
    "zod": "^4.3.6",
    "mongodb": "^6.16.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@tailwindcss/vite": "^4.1.11",
