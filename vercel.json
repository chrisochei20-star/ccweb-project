{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ccweb-api-production-a92c.up.railway.app/api/:path*"
    },
    {
      "source": "/v1/:path*",
      "destination": "https://ccweb-api-production-a92c.up.railway.app/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
